{
    "name": "waaseyaa/ai-observability",
    "description": "Trace recording, cost tracking, and anomaly detection for Waaseyaa agentic framework",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../ai-agent"},
        {"type": "path", "url": "../ai-pipeline"},
        {"type": "path", "url": "../api"},
        {"type": "path", "url": "../database-legacy"},
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../entity-storage"},
        {"type": "path", "url": "../foundation"}
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/ai-agent": "^0.1.0-alpha.188",
        "waaseyaa/ai-pipeline": "^0.1.0-alpha.188",
        "waaseyaa/api": "^0.1.0-alpha.188",
        "waaseyaa/database-legacy": "^0.1.0-alpha.188",
        "waaseyaa/entity": "^0.1.0-alpha.188",
        "waaseyaa/entity-storage": "^0.1.0-alpha.188",
        "waaseyaa/foundation": "^0.1.0-alpha.188"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {"Waaseyaa\\AI\\Observability\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Waaseyaa\\AI\\Observability\\Tests\\": "tests/"}
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\AI\\Observability\\AgentTelemetryServiceProvider",
                "Waaseyaa\\AI\\Observability\\ObservabilityServiceProvider"
            ],
            "migrations": "migrations"
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {"sort-packages": true}
}
